      },
      {
        "bindingId": "parity-runner-mcp",
        "adapterId": "mcp-ts-main",
        "agentId": "parity-runner",
        "sessionId": "parity-runner-session",
        "profileId": "parity-runner",
        "serverNames": ["den", "memory"],
        "endpointRef": "config://mcp/parity-runner",
        "transport": "streamable_http",
        "toolProfileKey": "planner",
        "status": "active"
