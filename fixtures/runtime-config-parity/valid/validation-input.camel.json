{
  "runtimeConfig": {
    "profilesDir": "__FIXTURE_ROOT__/profiles",
    "skillsDir": "__FIXTURE_ROOT__/skills",
    "brains": [
      {
        "implementationId": "parity-runner-brain",
        "profileId": "parity-runner"
      }
    ],
    "sessions": [
      {
        "sessionId": "parity-runner-session",
