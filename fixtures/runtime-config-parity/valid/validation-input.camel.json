      },
      {
        "id": "parity-runner-maintenance",
        "schedule": "0 4 * * *",
        "shape": "host_job",
        "jobKind": "runtime.review.memory_skills"
      },
      {
        "id": "background-review-parity-runner",
        "schedule": "0 3 * * *",
        "shape": "host_job",
        "jobKind": "runtime.review.memory_skills"
      }
    ],
    "channelBindings": [
      {
        "bindingId": "parity-runner-channel",
