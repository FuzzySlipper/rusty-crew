{
  "name": "rusty-crew",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "ts/packages/*"
  ],
  "scripts": {
    "build:native": "npm run build:native -w @rusty-crew/native-bridge",
    "build": "npm run typecheck",
    "measure:napi": "npm run measure:napi -w @rusty-crew/native-bridge",
    "smoke:brain": "npm run smoke:wake -w @rusty-crew/brain-island",
    "smoke:bridge-wake": "npm run smoke:bridge-wake -w @rusty-crew/brain-island",
    "smoke:registered-bridge-wake": "npm run smoke:registered-bridge-wake -w @rusty-crew/brain-island",
    "smoke:production-delegation-wake": "npm run smoke:production-delegation-wake -w @rusty-crew/brain-island",
    "smoke:production-local-tools-wake": "npm run smoke:production-local-tools-wake -w @rusty-crew/brain-island",
    "smoke:production-patch-wake": "npm run smoke:production-patch-wake -w @rusty-crew/brain-island",
    "smoke:delegated-role-assembly": "npm run smoke:delegated-role-assembly -w @rusty-crew/brain-island",
    "smoke:delegated-slice": "npm run smoke:delegated-slice -w @rusty-crew/brain-island",
    "smoke:tool-registry": "npm run smoke:tool-registry -w @rusty-crew/brain-island",
    "smoke:tool-registry-diagnostics": "npm run smoke:tool-registry-diagnostics -w @rusty-crew/brain-island",
    "smoke:tool-profile-selection": "npm run smoke:tool-profile-selection -w @rusty-crew/brain-island",
    "smoke:profile-loading": "npm run smoke:profile-loading -w @rusty-crew/brain-island",
    "smoke:profile-role-assembly": "npm run smoke:profile-role-assembly -w @rusty-crew/brain-island",
    "smoke:tool-session-selection": "npm run smoke:tool-session-selection -w @rusty-crew/brain-island",
    "smoke:local-code-tools": "npm run smoke:local-code-tools -w @rusty-crew/brain-island",
    "smoke:patch-tool": "npm run smoke:patch-tool -w @rusty-crew/brain-island",
    "smoke:den": "npm run smoke -w @rusty-crew/adapter-den",
    "smoke:mid-turn": "npm run smoke:mid-turn -w @rusty-crew/brain-island",
    "typecheck": "tsc --noEmit -p ts/packages/contracts && tsc --noEmit -p ts/packages/native-bridge && tsc --noEmit -p ts/packages/core-bridge && tsc --noEmit -p ts/packages/brain-island && tsc --noEmit -p ts/packages/adapter-den && tsc --noEmit -p ts/packages/adapter-telegram && tsc --noEmit -p ts/packages/adapter-mcp && tsc --noEmit -p ts/packages/adapter-tui",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.22.1",
    "typescript": "^5.8.0"
  },
  "allowScripts": {
    "@google/genai@1.52.0": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.6.4": true
  }
}
