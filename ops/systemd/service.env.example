RUSTY_CREW_DATA_DIR=/home/system/rusty-crew
RUSTY_CREW_CONFIG_DIR=/home/system/rusty-crew/config
RUSTY_CREW_ENGINE_DATA_DIR=/home/system/rusty-crew/data/engine
RUSTY_CREW_LOG_DIR=/home/system/rusty-crew/logs
RUSTY_CREW_RUN_DIR=/home/system/rusty-crew/run
RUSTY_CREW_ARTIFACT_DIR=/home/system/rusty-crew/artifacts
RUSTY_CREW_BACKUP_DIR=/home/system/rusty-crew/backups
# Optional override. When unset, /home/system/rusty-crew/site is served if it exists.
# RUSTY_CREW_STATIC_DIR=/home/system/rusty-crew/site
RUSTY_CREW_DEFAULT_WORKDIR=/home
RUSTY_CREW_ADMIN_HOST=0.0.0.0
RUSTY_CREW_ADMIN_PORT=9347
RUSTY_CREW_ADMIN_ALLOW_LAN=true
RUSTY_CREW_ADMIN_AUTH_MODE=bearer
RUSTY_CREW_ADMIN_TOKEN=replace-with-local-token

# SQLite remains supported for small/container deployments. The shared local
# service uses PostgreSQL; put the actual RUSTY_CREW_DATABASE_URL in a separate
# secret EnvironmentFile such as /home/system/database/rusty-crew-postgres.env.
RUSTY_CREW_STORAGE_BACKEND=postgres
RUSTY_CREW_POSTGRES_BOOT_MODE=active
RUSTY_CREW_POSTGRES_DATABASE_URL_ENV=RUSTY_CREW_DATABASE_URL
RUSTY_CREW_POSTGRES_SCHEMA=rusty_crew
RUSTY_CREW_POSTGRES_MAX_CONNECTIONS=10
RUSTY_CREW_POSTGRES_STATEMENT_TIMEOUT_MS=30000

RUSTY_CREW_SCHEDULER_TICK_INTERVAL_MS=1000
RUSTY_CREW_WAKE_DISPATCH_INTERVAL_MS=250

# Enable live OpenAI Responses through direct provider aliases. Direct OpenAI
# OAuth providers store their tokens in typed provider credential envelopes, so
# they do not need RUSTY_CREW_OPENAI_RESPONSES_ALLOW_NO_KEY.
# Use ALLOW_NO_KEY only for an explicit proxy endpoint that handles credentials
# itself, such as a compatibility den-router smoke.
# RUSTY_CREW_OPENAI_RESPONSES_LIVE=1
# RUSTY_CREW_OPENAI_RESPONSES_REQUIRE_NATIVE=1
# RUSTY_CREW_OPENAI_RESPONSES_STREAM_IDLE_TIMEOUT_MS=300000

# Optional MCP facade used to resolve profile bindings such as
# config://mcp/rusty-crew-runner into profile-scoped JSON-RPC endpoints.
# The service appends/overwrites tool_profile=<binding.toolProfileKey>.
# RUSTY_CREW_MCP_BASE_URL=http://192.168.1.10:5199/mcp
# RUSTY_CREW_MCP_REQUEST_TIMEOUT_MS=30000

# Optional Den Memories client for den_memory_* brain tools.
# Leave unset to keep Den memory tools selected-but-client-unavailable with
# explicit diagnostics. Do not commit real tokens here.
# RUSTY_CREW_DEN_MEMORY_BASE_URL=http://127.0.0.1:19999
# RUSTY_CREW_DEN_MEMORY_TOKEN=replace-with-den-memory-token
# Use den-memories-v0 for the current standalone Den Memories service at :8780.
# Leave unset for the newer /v1/memories/* client shape.
# RUSTY_CREW_DEN_MEMORY_API_MODE=den-memories-v0
# RUSTY_CREW_DEN_MEMORY_TIMEOUT_MS=5000
# Standalone Den Memories v0 paths:
# RUSTY_CREW_DEN_MEMORY_RECALL_PATH=/api/recall
# RUSTY_CREW_DEN_MEMORY_READ_PATH=/api/memory-entries
# RUSTY_CREW_DEN_MEMORY_SEARCH_PATH=/api/memory-entries/search
# RUSTY_CREW_DEN_MEMORY_STORE_PATH=/api/memory-entries
# RUSTY_CREW_DEN_MEMORY_PROPOSE_PATH=/api/candidates
# Newer v1 paths:
# RUSTY_CREW_DEN_MEMORY_RECALL_PATH=/v1/memories/recall
# RUSTY_CREW_DEN_MEMORY_READ_PATH=/v1/memories/read
# RUSTY_CREW_DEN_MEMORY_SEARCH_PATH=/v1/memories/search
# RUSTY_CREW_DEN_MEMORY_STORE_PATH=/v1/memories/store
# RUSTY_CREW_DEN_MEMORY_PROPOSE_PATH=/v1/memories/propose
